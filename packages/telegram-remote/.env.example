# Telegram Remote gateway (v0) — copy to .env and fill in. See README.md.

# Required: Telegram bot token from @BotFather.
GJC_TELEGRAM_REMOTE_BOT_TOKEN=123456:telegram-bot-token

# Default-deny allowlist. Provide at least one of user ids or chat ids (comma-separated).
GJC_TELEGRAM_REMOTE_ALLOWED_USER_IDS=11111111
# GJC_TELEGRAM_REMOTE_ALLOWED_CHAT_IDS=-1001234567890

# Approved presets (JSON array). Only a preset id may be named from chat.
GJC_TELEGRAM_REMOTE_PRESETS=[{"id":"proj","workdir":"/home/bot/src/project","sessionCommand":"gjc --worktree","taskTemplate":"Use /skill:ralplan to plan: {{task}}","taskMaxLen":2000}]

# Enable /stop (adds the `reports` mutation class). Omit/false to stay read+start only.
GJC_TELEGRAM_REMOTE_ENABLE_STOP=false

# Optional tuning.
# GJC_TELEGRAM_REMOTE_DEFAULT_TASK_MAX_LEN=2000
# GJC_TELEGRAM_REMOTE_POLL_TIMEOUT_SEC=30
# GJC_TELEGRAM_REMOTE_API_BASE=https://api.telegram.org

# Optional coordinator overrides (defaults: gjc mcp-serve coordinator).
# GJC_TELEGRAM_REMOTE_COORDINATOR_COMMAND=gjc
# GJC_TELEGRAM_REMOTE_COORDINATOR_ARGS=mcp-serve,coordinator

# Optional coordinator namespace/state passthrough.
# GJC_COORDINATOR_MCP_WORKDIR_ROOTS=/home/bot/src/project
# GJC_COORDINATOR_MCP_SESSION_COMMAND=gjc --worktree
# GJC_COORDINATOR_MCP_PROFILE=telegram-remote
# GJC_COORDINATOR_MCP_REPO=project
# GJC_COORDINATOR_MCP_STATE_ROOT=
# GJC_COORDINATOR_MCP_ARTIFACT_BYTE_CAP=
